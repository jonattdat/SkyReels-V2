# ---------------------------------------------------------------------------
# SkyReels-V2 Studio — frontend environment
# Copy to `.env.local` for local dev, or set these in the Vercel dashboard.
# ---------------------------------------------------------------------------

# URL of your SkyReels-V2 inference API (api_server.py running on a GPU host).
# Leave UNSET to run the site in stateless demo mode (synthetic previews,
# no GPU required) — handy for a first Vercel deploy before wiring a backend.
#
# Examples:
#   SKYREELS_API_URL=https://skyreels-api.your-domain.com
#   SKYREELS_API_URL=https://abcd-1234.ngrok-free.app
SKYREELS_API_URL=

# Optional shared secret. If your api_server.py sets SKYREELS_API_KEY, put the
# same value here. It is attached server-side by the Next.js API routes and is
# never exposed to the browser.
SKYREELS_API_KEY=
