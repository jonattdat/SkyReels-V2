# ---------------------------------------------------------------------------
# SkyReels Studio — frontend environment
# Copy to `.env.local` for local dev, or set these in the Vercel dashboard
# (Project → Settings → Environment Variables).
# ---------------------------------------------------------------------------

# How the studio reaches a model. Pick ONE of the three setups below.

# --- Option A (recommended): SkyReels' hosted API — NO GPU needed -----------
# Get an API key at https://www.skyreels.ai (Account → API Keys). The studio
# auto-detects the hosted API and adapts to its V3/V4 models + Talking Avatar.
#   SKYREELS_API_URL=https://api-gateway.skyreels.ai
#   SKYREELS_API_KEY=your-skyreels-api-key

# --- Option B: your own self-hosted GPU backend (api_server.py) -------------
#   SKYREELS_API_URL=https://your-gpu-host.example.com
#   SKYREELS_API_KEY=your-shared-secret   # only if the backend sets one

# --- Option C: demo mode -----------------------------------------------------
# Leave both UNSET. The site runs a self-contained demo (synthetic previews),
# so the deployment is interactive before you connect any backend.

SKYREELS_API_URL=
SKYREELS_API_KEY=

# Optional: force the hosted-API adapter even if the URL isn't recognized.
# SKYREELS_PROVIDER=skyreels-cloud
